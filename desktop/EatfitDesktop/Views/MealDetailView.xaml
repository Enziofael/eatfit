<UserControl x:Class="EatfitDesktop.Views.MealDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30" MaxWidth="550">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Width="80" Height="80" CornerRadius="40" 
                    Background="#667eea" Margin="0,0,0,15">
                <TextBlock Text="🍽" FontSize="36" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Row="1" x:Name="NameText" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="2" x:Name="KcalText" FontSize="16" Foreground="#666" Margin="0,0,0,20"/>

            <!-- КБЖУ -->
            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="Calories" Foreground="#999" FontSize="11"/>
                        <TextBlock x:Name="CaloriesText" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="Proteins" Foreground="#999" FontSize="11"/>
                        <TextBlock x:Name="ProteinsText" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="Fats" Foreground="#999" FontSize="11"/>
                        <TextBlock x:Name="FatsText" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="Carbs" Foreground="#999" FontSize="11"/>
                        <TextBlock x:Name="CarbsText" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="Water" Foreground="#999" FontSize="11"/>
                        <TextBlock x:Name="WaterText" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Состав -->
            <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15"
                    x:Name="ComponentsPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Components" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="ComponentsList"/>
                </StackPanel>
            </Border>

            <!-- Описание -->
            <Border Grid.Row="5" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15"
                    x:Name="DescriptionPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Description" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Foreground="#444"/>
                </StackPanel>
            </Border>

            <!-- Рецепт -->
            <Border Grid.Row="6" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15"
                    x:Name="RecipePanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Recipe" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,5"/>
                    <TextBlock x:Name="RecipeText" TextWrapping="Wrap" Foreground="#444"/>
                </StackPanel>
            </Border>

            <!-- Кнопка назад -->
            <Button Grid.Row="7" Content="← Back" Style="{StaticResource LinkButton}" 
                    HorizontalAlignment="Left" Click="Back_Click"/>
        </Grid>
    </ScrollViewer>
</UserControl>