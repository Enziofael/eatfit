<Window x:Class="EatfitDesktop.Views.NormsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Norms" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1" Text="Calories (kcal):" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="CaloriesBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Proteins (g):" Margin="0,0,0,5"/>
        <TextBox Grid.Row="4" x:Name="ProteinsBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Text="Fats (g):" Margin="0,0,0,5"/>
        <TextBox Grid.Row="6" x:Name="FatsBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="7" Text="Carbs (g):" Margin="0,0,0,5"/>
        <TextBox Grid.Row="8" x:Name="CarbsBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="9" Text="Water (ml):" Margin="0,0,0,5"/>
        <TextBox Grid.Row="10" x:Name="WaterBox" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>