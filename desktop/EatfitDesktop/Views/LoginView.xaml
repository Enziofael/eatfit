<UserControl x:Class="EatfitDesktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="420" Width="380">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Eatfit" FontSize="36" FontWeight="Bold"
                   Foreground="#667eea" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Поля ввода -->
        <TextBlock Grid.Row="1" Text="Email or Login" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="2" Text="{Binding LoginIdentifier, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Text="Password" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox"/>

        <!-- Ошибка -->
        <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}" Foreground="#e74c3c" 
                   TextWrapping="Wrap" FontSize="12" Margin="0,0,0,5" MaxHeight="35"/>

        <!-- Кнопка Login -->
        <Button Grid.Row="6" Content="Login" Command="{Binding LoginCommand}" 
                Style="{StaticResource PrimaryButton}" Width="200" 
                HorizontalAlignment="Center" Margin="0,10,0,0"/>

        <!-- Кнопка Register -->
        <Button Grid.Row="7" Content="Create new account" Command="{Binding RegisterCommand}" 
                Style="{StaticResource LinkButton}" HorizontalAlignment="Center" Margin="0,5,0,0"/>

        <!-- Кнопка Forgot Password (более заметная) -->
        <Button Grid.Row="8" Content="Forgot password?" Command="{Binding ForgotPasswordCommand}" 
                Background="Transparent" Foreground="#888" BorderThickness="0"
                Cursor="Hand" FontSize="13" Height="30" Width="160"
                HorizontalAlignment="Center" Margin="0,2,0,0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <TextBlock Text="{TemplateBinding Content}" 
                               Foreground="{TemplateBinding Foreground}"
                               TextDecorations="Underline"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>