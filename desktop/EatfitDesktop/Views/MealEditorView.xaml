<UserControl x:Class="EatfitDesktop.Views.MealEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30" MaxWidth="550">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" x:Name="TitleText" Text="Create Meal" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Название -->
            <TextBlock Grid.Row="1" Text="Name *" Style="{StaticResource LabelText}"/>
            <TextBox Grid.Row="2" x:Name="NameBox" Margin="0,0,0,10"/>

            <!-- Описание -->
            <TextBlock Grid.Row="3" Text="Description" Style="{StaticResource LabelText}"/>
            <TextBox Grid.Row="4" x:Name="DescriptionBox" Height="60" TextWrapping="Wrap" 
                     AcceptsReturn="True" Margin="0,0,0,10"/>

            <!-- Рецепт -->
            <TextBlock Grid.Row="5" Text="Recipe" Style="{StaticResource LabelText}"/>
            <TextBox Grid.Row="6" x:Name="RecipeBox" Height="80" TextWrapping="Wrap" 
                     AcceptsReturn="True" Margin="0,0,0,10"/>

            <!-- Компоненты -->
            <Border Grid.Row="7" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Components" FontWeight="SemiBold" FontSize="15"/>
                        <Button Content="+ Add Component" Style="{StaticResource LinkButton}" 
                                Width="130" Margin="10,0,0,0" Click="AddComponent_Click"/>
                    </StackPanel>
                    <TextBlock Text="If components are added, nutrition will be calculated automatically." 
                               Foreground="#999" FontSize="11" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="ComponentsList"/>
                </StackPanel>
            </Border>

            <!-- КБЖУ (ручной ввод) -->
            <Border Grid.Row="8" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Nutrition (per 100g)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock Text="Leave 0 to auto-calculate from components" 
                               Foreground="#999" FontSize="11" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,5">
                            <TextBlock Text="Calories" FontSize="11" Foreground="#999"/>
                            <TextBox x:Name="CaloriesBox" Text="0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,5,5">
                            <TextBlock Text="Proteins (g)" FontSize="11" Foreground="#999"/>
                            <TextBox x:Name="ProteinsBox" Text="0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,5">
                            <TextBlock Text="Fats (g)" FontSize="11" Foreground="#999"/>
                            <TextBox x:Name="FatsBox" Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Carbs (g)" FontSize="11" Foreground="#999"/>
                            <TextBox x:Name="CarbsBox" Text="0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,5,0">
                            <TextBlock Text="Water (ml)" FontSize="11" Foreground="#999"/>
                            <TextBox x:Name="WaterBox" Text="0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Ошибка -->
            <TextBlock Grid.Row="9" x:Name="ErrorText" Foreground="#e74c3c" FontSize="12" Margin="0,0,0,10"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Height="35" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Save" Width="100" Height="35" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>