# ============================================
# Eatfit Environment Configuration
# ============================================

# Project
PROJECT_NAME=eatfit
APP_ENV=development
APP_DEBUG=true

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eatfit_user
POSTGRES_PASSWORD=eatfit_pass
POSTGRES_DB=eatfit

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Server
BACKEND_GRPC_PORT=50051
BACKEND_HTTP_PORT=8080
BACKEND_HOST=0.0.0.0

# Security
JWT_SECRET=change_me_in_production_use_random_256bit_key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=720h

# Email (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@eatfit.local
EMAIL_FROM_NAME=Eatfit

# Production email settings (uncomment for production)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# EMAIL_FROM=noreply@eatfit.com
# EMAIL_FROM_NAME=Eatfit

# Android Emulator
# ANDROID_GRPC_HOST=10.0.2.2  # For Android Emulator
# ANDROID_GRPC_HOST=192.168.x.x  # For physical device (use your local IP)
