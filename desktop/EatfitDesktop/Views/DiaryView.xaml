<UserControl x:Class="EatfitDesktop.Views.DiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,15,0">
                <!-- Прогресс -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Daily Progress" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10"/>
                        <DatePicker x:Name="DayPicker" SelectedDateChanged="DayPicker_SelectedDateChanged"/>

                        <TextBlock Text="Calories" Margin="0,10,0,5" FontSize="12" Foreground="#666"/>
                        <Grid>
                            <Border Height="20" Background="#e8eaf6" CornerRadius="10"/>
                            <Border x:Name="CalBar" Height="20" Background="#667eea" CornerRadius="10" HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="CalText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>

                        <TextBlock Text="Proteins" Margin="0,10,0,5" FontSize="12" Foreground="#666"/>
                        <Grid>
                            <Border Height="20" Background="#e0f2f1" CornerRadius="10"/>
                            <Border x:Name="ProtBar" Height="20" Background="#11998e" CornerRadius="10" HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="ProtText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>

                        <TextBlock Text="Fats" Margin="0,10,0,5" FontSize="12" Foreground="#666"/>
                        <Grid>
                            <Border Height="20" Background="#fce4ec" CornerRadius="10"/>
                            <Border x:Name="FatBar" Height="20" Background="#f5576c" CornerRadius="10" HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="FatText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>

                        <TextBlock Text="Carbs" Margin="0,10,0,5" FontSize="12" Foreground="#666"/>
                        <Grid>
                            <Border Height="20" Background="#fff3e0" CornerRadius="10"/>
                            <Border x:Name="CarbBar" Height="20" Background="#ff9800" CornerRadius="10" HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="CarbText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>

                        <TextBlock Text="Water" Margin="0,10,0,5" FontSize="12" Foreground="#666"/>
                        <Grid>
                            <Border Height="20" Background="#e3f2fd" CornerRadius="10"/>
                            <Border x:Name="WaterBar" Height="20" Background="#2196f3" CornerRadius="10" HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="WaterText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- График веса -->
                <Border Background="White" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Button Content="◀" Style="{StaticResource IconButton}" Width="30" Height="30" Click="PrevMonth_Click"/>
                            <TextBlock x:Name="MonthText" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="10,0"/>
                            <Button Content="▶" Style="{StaticResource IconButton}" Width="30" Height="30" Click="NextMonth_Click"/>
                        </StackPanel>
                        <Border Height="180" Background="#fafafa" CornerRadius="4">
                            <Canvas x:Name="WeightCanvas"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Column="1" Width="3" Background="#e0e0e0" HorizontalAlignment="Center"/>

        <!-- Правая панель -->
        <Grid Grid.Column="2" Margin="15,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Margin="0,0,10,0" Height="35" KeyDown="SearchBox_KeyDown"/>
                    <Button Grid.Column="1" Content="🔍" Width="35" Height="35" Style="{StaticResource IconButton}" Click="Search_Click"/>
                    <Button Grid.Column="2" Content="＋" Width="35" Height="35" Margin="5,0,0,0" Style="{StaticResource IconButton}" Click="AddConsumption_Click" FontWeight="Bold" Foreground="#11998e"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1">
                <ItemsControl x:Name="ConsumptionList"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>