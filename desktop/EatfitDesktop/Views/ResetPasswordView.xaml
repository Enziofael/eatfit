<UserControl x:Class="EatfitDesktop.Views.ResetPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="420" Width="380">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Reset Password" Style="{StaticResource HeaderText}"/>

        <TextBlock Grid.Row="1" Text="Verification Code" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="2" Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="16" TextAlignment="Center" MaxLength="6"/>

        <TextBlock Grid.Row="3" Text="New Password" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="4" x:Name="NewPasswordBox"/>

        <TextBlock Grid.Row="5" Text="Confirm Password" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="6" x:Name="ConfirmPasswordBox"/>

        <StackPanel Grid.Row="7" Margin="0,15,0,0">
            <Button Content="Reset Password" Command="{Binding ResetPasswordCommand}" 
                    Style="{StaticResource PrimaryButton}"/>
            <Button Content="← Back to login" Command="{Binding LoginCommand}" 
                    Style="{StaticResource LinkButton}" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>