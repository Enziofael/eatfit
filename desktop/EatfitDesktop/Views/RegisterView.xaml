<UserControl x:Class="EatfitDesktop.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="480" Width="380">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Create Account" Style="{StaticResource HeaderText}"/>

        <TextBlock Grid.Row="1" Text="Email" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="2" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Text="Login" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="4" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="5" Text="Password" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="6" x:Name="PasswordBox"/>

        <TextBlock Grid.Row="7" Text="Confirm Password" Style="{StaticResource LabelText}"/>
        <PasswordBox Grid.Row="8" x:Name="ConfirmPasswordBox"/>

        <StackPanel Grid.Row="9">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#e74c3c" 
                       TextWrapping="Wrap" FontSize="12" Margin="0,0,0,5" MaxHeight="30"/>

            <Button Content="Register" Command="{Binding RegisterCommand}" 
                    Style="{StaticResource PrimaryButton}" Width="200" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            <Button Content="Already have account? Login" Command="{Binding LoginCommand}" 
                    Style="{StaticResource LinkButton}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>