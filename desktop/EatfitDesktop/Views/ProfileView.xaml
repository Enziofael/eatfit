<UserControl x:Class="EatfitDesktop.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30" MaxWidth="600">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="80" Height="80" CornerRadius="40" 
                        Background="#667eea" Margin="0,0,15,0">
                    <TextBlock Text="👤" FontSize="36" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Login}" Foreground="#999" FontSize="13" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Bio}" Foreground="#666" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <!-- Кнопка настроек -->
                <Button  Content="⚙️ Settings" 
                    Style="{StaticResource LinkButton}" Margin="0,0,10,0"
                    HorizontalAlignment="Left"
                     Click="Settings_Click"/>
                <Button  Content="🚪 Logout" 
                    Style="{StaticResource LinkButton}"
                    HorizontalAlignment="Center"
                    Click="Logout_Click"/>
            </StackPanel>

            <!-- Информация -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Height" Foreground="#999" FontSize="12"/>
                        <TextBlock Text="{Binding Height}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Current Weight" Foreground="#999" FontSize="12"/>
                            <Button Content="✏️" Style="{StaticResource IconButton}" 
                                    Margin="5,0,0,0" Command="{Binding UpdateWeightCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Weight}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Age" Foreground="#999" FontSize="12"/>
                        <TextBlock Text="{Binding Age}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Gender" Foreground="#999" FontSize="12"/>
                        <TextBlock Text="{Binding Gender}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="Birth Date" Foreground="#999" FontSize="12"/>
                        <TextBlock Text="{Binding BirthDate}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Нормы -->
            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Nutrition Norms" FontSize="16" FontWeight="SemiBold"/>
                        <Button Content="✏️" Style="{StaticResource IconButton}" 
                                Margin="5,0,0,0" Command="{Binding UpdateNormsCommand}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Calories" Foreground="#999" FontSize="11"/>
                            <TextBlock Text="{Binding Calories}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Proteins" Foreground="#999" FontSize="11"/>
                            <TextBlock Text="{Binding Proteins}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Fats" Foreground="#999" FontSize="11"/>
                            <TextBlock Text="{Binding Fats}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="Carbs" Foreground="#999" FontSize="11"/>
                            <TextBlock Text="{Binding Carbs}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <TextBlock Text="Water" Foreground="#999" FontSize="11"/>
                            <TextBlock Text="{Binding Water}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Публикации -->
            <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="My Publications" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="Your publications will appear here" Foreground="#999" FontSize="13"/>
                </StackPanel>
            </Border>


        </Grid>
    </ScrollViewer>
</UserControl>