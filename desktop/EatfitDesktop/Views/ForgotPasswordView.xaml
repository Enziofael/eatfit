<UserControl x:Class="EatfitDesktop.Views.ForgotPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="320" Width="380">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Forgot Password" Style="{StaticResource HeaderText}"/>

        <TextBlock Grid.Row="1" Text="Enter your email or login to receive reset code:" 
                   TextWrapping="Wrap" Margin="0,0,0,15" Foreground="#666"/>

        <TextBlock Grid.Row="2" Text="Email or Login" Style="{StaticResource LabelText}"/>
        <TextBox Grid.Row="3" Text="{Binding LoginIdentifier, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="#e74c3c" 
                   TextWrapping="Wrap" FontSize="12" Margin="0,5" MaxHeight="30"/>

        <StackPanel Grid.Row="5" Margin="0,10,0,0">
            <Button Content="Send Reset Code" Command="{Binding ResetPasswordCommand}" 
                    Style="{StaticResource PrimaryButton}" Width="200" HorizontalAlignment="Center"/>
            <Button Content="← Back to login" Command="{Binding LoginCommand}" 
                    Style="{StaticResource LinkButton}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>